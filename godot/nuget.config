<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <!-- Godot's MSBuild SDK + runtime packages (Godot.NET.Sdk, GodotSharp) are
         published to nuget.org, so restore works on any machine that's online.
         (Previously this pointed at a local Godot install's bundled nupkgs, which
         was machine-specific; nuget.org keeps the repo portable.) -->
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
</configuration>
