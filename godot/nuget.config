<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <!-- Godot ships its .NET SDK + GodotSharp packages locally; prefer them so
         the exact 4.4.1 SDK is always available offline. nuget.org is the
         fallback for everything else (xUnit etc. in the test project). -->
    <add key="godot-bundled" value="/opt/godot/Godot_v4.4.1-stable_mono_linux_x86_64/GodotSharp/Tools/nupkgs" />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
</configuration>
